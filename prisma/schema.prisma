datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

enum IssueCategory {
  SEO
  PERFORMANCE
  ACCESSIBILITY
  SECURITY
  MOBILE
  CONTENT
  UI_UX
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum ScanStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projects      Project[]
  scans         Scan[]
}

model Project {
  id          String   @id @default(uuid())
  userId      String
  name        String
  url         String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scans       Scan[]

  @@index([userId])
}

model Scan {
  id              String      @id @default(uuid())
  userId          String?
  projectId       String?
  url             String
  title           String?
  status          ScanStatus  @default(COMPLETED)
  overallScore    Int         @default(0)
  seoScore        Int         @default(0)
  performanceScore Int        @default(0)
  accessibilityScore Int      @default(0)
  securityScore   Int         @default(0)
  mobileScore     Int         @default(0)
  contentScore    Int         @default(0)
  uiScore         Int         @default(0)
  
  cmsDetected     String?
  frameworkDetected String?
  techStack       String[]    @default([])
  metadata        Json?
  durationMs      Int         @default(0)
  createdAt       DateTime    @default(now())

  user            User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  issues          Issue[]
  reports         Report[]
  chatMessages    ChatMessage[]

  @@index([userId])
  @@index([projectId])
  @@index([createdAt])
}

model Issue {
  id              String        @id @default(uuid())
  scanId          String
  category        IssueCategory
  severity        Severity
  title           String
  description     String
  whyItMatters    String?
  element         String?
  recommendation  String
  codeFix         String?
  seoImpact       Int           @default(0)
  uxImpact        Int           @default(0)
  createdAt       DateTime      @default(now())

  scan            Scan          @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([category])
  @@index([severity])
}

model Report {
  id          String   @id @default(uuid())
  scanId      String
  shareToken  String   @unique @default(uuid())
  format      String   @default("PDF")
  downloadUrl String?
  createdAt   DateTime @default(now())

  scan        Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  scanId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  scan      Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
}
